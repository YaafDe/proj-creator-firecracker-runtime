#!/usr/bin/env python3
import hashlib
import http.client
import json
import os
import re
import select
import shlex
import shutil
import socket
import subprocess
import sys
import threading
import time
from pathlib import Path


def log(message):
    print(message, file=sys.stderr, flush=True)


def emit_status(phase, message):
    print(json.dumps({
        "type": "status",
        "phase": phase,
        "message": message,
    }, separators=(",", ":")), flush=True)


def fail(message, code=70):
    log(f"firecracker-runner: {message}")
    raise SystemExit(code)


def require_command(name):
    path = shutil.which(name)
    if not path:
        fail(f"required command not found: {name}")
    return path


SENSITIVE_ASSIGNMENT_RE = re.compile(
    r"(?P<key>(?:[A-Za-z_][A-Za-z0-9_]*(?:_TOKEN|_KEY|_SECRET|_PASSWORD|_PASS|_CREDENTIAL|_CREDENTIALS)|PROMPT_B64|CODEX_RESUME_FALLBACK_PROMPT_B64))="
    r"(?P<value>'[^']*'|\"[^\"]*\"|[^\s'\";]+)"
)
BEARER_TOKEN_RE = re.compile(r"(?i)(bearer\s+)[A-Za-z0-9._~+/=-]+")


def redact_sensitive_text(value):
    value = SENSITIVE_ASSIGNMENT_RE.sub(lambda match: f"{match.group('key')}=<redacted>", value)
    return BEARER_TOKEN_RE.sub(r"\1<redacted>", value)


def format_command(command):
    parts = [str(part) for part in command]
    if len(parts) >= 3 and Path(parts[0]).name == "ssh" and parts[-3:-1] == ["bash", "-lc"]:
        parts = [*parts[:-1], "<remote-script>"]
    return redact_sensitive_text(shlex.join(parts))


def run(command, *, stdin=None, stdout=None, check=True, timeout=None):
    log("+ " + format_command(command))
    try:
        result = subprocess.run(
            command,
            stdin=stdin,
            stdout=stdout,
            check=False,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        if timeout is None:
            fail(f"command timed out: {format_command(command)}")
        fail(f"command timed out after {timeout}s: {format_command(command)}")
    if check and result.returncode != 0:
        fail(f"command failed with exit code {result.returncode}: {format_command(command)}")
    return result


def run_privileged(command, *, check=True):
    if os.geteuid() == 0:
        return run(command, check=check)
    sudo = require_command("sudo")
    return run([sudo, *command], check=check)


def run_quiet(command, *, check=False):
    return subprocess.run(
        command,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def run_privileged_quiet(command, *, check=False):
    if os.geteuid() == 0:
        return run_quiet(command, check=check)
    sudo = require_command("sudo")
    return run_quiet([sudo, *command], check=check)


class UnixHttpConnection(http.client.HTTPConnection):
    def __init__(self, socket_path):
        super().__init__("localhost")
        self.socket_path = socket_path

    def connect(self):
        self.sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.sock.connect(self.socket_path)


def firecracker_request(api_socket, method, path, body=None):
    conn = UnixHttpConnection(str(api_socket))
    payload = None if body is None else json.dumps(body).encode("utf-8")
    headers = {}
    if payload is not None:
        headers["Content-Type"] = "application/json"
    conn.request(method, path, body=payload, headers=headers)
    response = conn.getresponse()
    data = response.read().decode("utf-8", errors="replace")
    conn.close()
    if response.status >= 300:
        fail(f"Firecracker API {method} {path} failed with HTTP {response.status}: {data}")
    return data


def wait_for_path(path, seconds, label):
    deadline = time.monotonic() + seconds
    while time.monotonic() < deadline:
        if Path(path).exists():
            return
        time.sleep(0.1)
    fail(f"timed out waiting for {label}: {path}")


def wait_for_ssh(ssh_base, seconds):
    deadline = time.monotonic() + seconds
    while time.monotonic() < deadline:
        result = subprocess.run([*ssh_base, "true"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        if result.returncode == 0:
            return
        time.sleep(1)
    fail("timed out waiting for guest SSH")


def ssh_command(ssh_base, script, *, check=True, stdout=None, stdin=None):
    return run([*ssh_base, "bash", "-lc", shlex.quote(script)], check=check, stdout=stdout, stdin=stdin)


def terminate_process(process, name):
    if process.poll() is not None:
        return
    process.terminate()
    try:
        process.wait(timeout=5)
    except subprocess.TimeoutExpired:
        log(f"{name} did not exit after terminate; killing")
        process.kill()
        process.wait(timeout=5)


def tar_to_guest(ssh_base, source, destination):
    script = f"mkdir -p {shlex.quote(destination)} && tar -C {shlex.quote(destination)} -xf -"
    tar = subprocess.Popen(["tar", "-C", str(source), "-cf", "-", "."], stdout=subprocess.PIPE)
    try:
        ssh_command(ssh_base, script, stdin=tar.stdout)
    finally:
        if tar.stdout:
            tar.stdout.close()
    status = tar.wait()
    if status != 0:
        fail(f"workspace tar export failed with exit code {status}")


def chown_guest_workspace(root_ssh_base, destination, uid, gid):
    destination_q = shlex.quote(destination)
    owner_q = shlex.quote(f"{uid}:{gid}")
    ssh_command(root_ssh_base, f"chown -R {owner_q} {destination_q}")
    log(f"guest workspace ownership set to {uid}:{gid}: {destination}")


def chown_host_path(destination, uid, gid):
    run_privileged(["chown", "-R", f"{uid}:{gid}", str(destination)])
    log(f"host workspace ownership set to {uid}:{gid}: {destination}")


def container_workspace_target(workdir):
    if workdir.startswith("/workspace/"):
        return "/workspace"
    if workdir.startswith("/"):
        return workdir
    return f"/workspace/{workdir}"


def sync_host_path_to_guest(root_ssh_base, host_path, guest_path, uid, gid):
    host = Path(host_path)
    if not host.exists():
        fail(f"Firecracker support mount source does not exist: {host_path}")

    guest_path_q = shlex.quote(guest_path)
    if host.is_dir():
        script = f"mkdir -p {guest_path_q} && tar -C {guest_path_q} -xf -"
        tar = subprocess.Popen(["tar", "-C", str(host), "-cf", "-", "."], stdout=subprocess.PIPE)
        try:
            ssh_command(root_ssh_base, script, stdin=tar.stdout)
        finally:
            if tar.stdout:
                tar.stdout.close()
        status = tar.wait()
        if status != 0:
            fail(f"support mount tar export failed with exit code {status}: {host_path}")
    else:
        mode = host.stat().st_mode & 0o777
        parent_q = shlex.quote(str(Path(guest_path).parent))
        with host.open("rb") as source:
            ssh_command(
                root_ssh_base,
                f"mkdir -p {parent_q} && cat > {guest_path_q} && chmod {mode:o} {guest_path_q}",
                stdin=source,
            )
    chown_guest_workspace(root_ssh_base, guest_path, uid, gid)


def tar_from_guest(ssh_base, source, destination):
    tar = subprocess.Popen(["tar", "-C", str(destination), "-xf", "-"], stdin=subprocess.PIPE)
    try:
        script = f"tar --exclude=.git -C {shlex.quote(source)} -cf - ."
        ssh_command(ssh_base, script, stdout=tar.stdin)
    finally:
        if tar.stdin:
            tar.stdin.close()
    status = tar.wait()
    if status != 0:
        fail(f"workspace tar import failed with exit code {status}")


def fetch_guest_file(ssh_base, source, destination):
    source_q = shlex.quote(source)
    destination.parent.mkdir(parents=True, exist_ok=True)
    with destination.open("wb") as output:
        result = ssh_command(
            ssh_base,
            f"if [ -f {source_q} ]; then cat {source_q}; fi",
            check=False,
            stdout=output,
        )
    if result.returncode != 0:
        log(f"failed to fetch guest file {source}: ssh exited {result.returncode}")


def sync_mount_back_to_host(root_ssh_base, mount, uid, gid):
    if mount.get("read_only"):
        return
    purpose = str(mount.get("purpose") or "")
    if purpose not in {"runtime_support", "claude_session", "codex_session"}:
        return
    host_path = Path(str(mount.get("host_path") or ""))
    guest_path = str(mount.get("guest_path") or "")
    if not host_path.is_dir() or not guest_path:
        return
    log(f"syncing Firecracker support mount back from guest {guest_path} to {host_path}")
    tar_from_guest(root_ssh_base, guest_path, host_path)
    chown_host_path(host_path, uid, gid)


def load_docker_image_to_guest(ssh_base, image):
    inspect_timeout_seconds = int(os.environ.get(
        "PROJ_CREATOR_FIRECRACKER_DOCKER_INSPECT_TIMEOUT_SECONDS",
        "60",
    ))
    run(
        ["docker", "image", "inspect", image],
        stdout=subprocess.DEVNULL,
        timeout=inspect_timeout_seconds,
    )
    timeout_seconds = int(os.environ.get("PROJ_CREATOR_FIRECRACKER_DOCKER_LOAD_TIMEOUT_SECONDS", "900"))
    save = subprocess.Popen(["docker", "save", image], stdout=subprocess.PIPE)
    ssh = None
    try:
        ssh = subprocess.Popen(
            [*ssh_base, "bash", "-lc", shlex.quote("docker load")],
            stdin=save.stdout,
        )
        if save.stdout:
            save.stdout.close()
        deadline = time.monotonic() + timeout_seconds
        while True:
            save_status = save.poll()
            ssh_status = ssh.poll()
            if save_status is not None and ssh_status is not None:
                break
            if time.monotonic() > deadline:
                terminate_process(save, "docker save")
                terminate_process(ssh, "guest docker load")
                fail(f"timed out after {timeout_seconds}s loading Docker image into guest: {image}")
            time.sleep(0.5)
    finally:
        if save.stdout:
            save.stdout.close()
        if ssh is not None:
            terminate_process(ssh, "guest docker load")
    status = save.wait()
    if status != 0:
        fail(f"docker save failed with exit code {status}: {image}")
    ssh_status = ssh.wait() if ssh is not None else 1
    if ssh_status != 0:
        fail(f"guest docker load failed with exit code {ssh_status}: {image}")


def parse_size(value):
    value = value.strip()
    if not value:
        fail("empty rootfs size")
    suffix = value[-1].upper()
    multipliers = {"K": 1024, "M": 1024 ** 2, "G": 1024 ** 3, "T": 1024 ** 4}
    if suffix in multipliers:
        return int(float(value[:-1]) * multipliers[suffix])
    return int(value)


def grow_rootfs(rootfs):
    target_size = os.environ.get("PROJ_CREATOR_FIRECRACKER_RUN_ROOTFS_SIZE", "50G")
    target_bytes = parse_size(target_size)
    current_bytes = rootfs.stat().st_size
    if current_bytes >= target_bytes:
        log(f"rootfs already {current_bytes} bytes; target is {target_size}")
        return
    log(f"growing run rootfs from {current_bytes} bytes to {target_size}")
    run(["truncate", "-s", target_size, str(rootfs)])
    run(["e2fsck", "-fy", str(rootfs)])
    run(["resize2fs", str(rootfs)])


def rootfs_user_ids(mount_dir, user):
    passwd_path = mount_dir / "etc" / "passwd"
    try:
        with passwd_path.open("r", encoding="utf-8") as passwd:
            for line in passwd:
                fields = line.rstrip("\n").split(":")
                if len(fields) >= 4 and fields[0] == user:
                    return fields[2], fields[3]
    except OSError as err:
        fail(f"failed to read guest passwd database {passwd_path}: {err}")
    fail(f"guest user not found in {passwd_path}: {user}")


def inject_ssh_key(rootfs, mount_dir, public_key):
    run_privileged(["mount", "-o", "loop", str(rootfs), str(mount_dir)])
    try:
        for user, home in [
            ("root", "root"),
            ("appuser", "home/appuser"),
        ]:
            uid, gid = rootfs_user_ids(mount_dir, user)
            ssh_dir = mount_dir / home / ".ssh"
            authorized_keys = ssh_dir / "authorized_keys"
            run_privileged(["mkdir", "-p", str(ssh_dir)])
            run_privileged(["sh", "-c", f"printf '%s\n' {shlex.quote(public_key)} >> {shlex.quote(str(authorized_keys))}"])
            run_privileged(["chmod", "0700", str(ssh_dir)])
            run_privileged(["chmod", "0600", str(authorized_keys)])
            run_privileged(["chown", "-R", f"{uid}:{gid}", str(ssh_dir)])
            log(f"injected SSH key for {user}")
    finally:
        run_privileged(["umount", str(mount_dir)], check=False)


def stable_network(run_dir):
    digest = hashlib.sha256(str(run_dir).encode("utf-8")).digest()
    octet = 16 + digest[0] % 200
    host_ip = f"172.31.{octet}.1"
    guest_ip = f"172.31.{octet}.2"
    mac = f"06:00:ac:1f:{octet:02x}:02"
    tap = f"pcfc{digest[1]:02x}{digest[2]:02x}{digest[3]:02x}"[:15]
    return tap, host_ip, guest_ip, mac


def guest_subnet(host_ip):
    return ".".join(host_ip.split(".")[:3]) + ".0/24"


def iptables_rule_exists(args):
    return run_privileged_quiet(["iptables", *args], check=False).returncode == 0


def ensure_iptables_rule(table, chain, rule):
    check_args = []
    if table:
        check_args.extend(["-t", table])
    check_args.extend(["-C", chain, *rule])
    if iptables_rule_exists(check_args):
        return None

    add_args = []
    if table:
        add_args.extend(["-t", table])
    add_args.extend(["-A", chain, *rule])
    run_privileged(["iptables", *add_args])

    delete_args = []
    if table:
        delete_args.extend(["-t", table])
    delete_args.extend(["-D", chain, *rule])
    return ["iptables", *delete_args]


def setup_guest_nat(tap, host_ip):
    require_command("iptables")
    require_command("sysctl")
    subnet = guest_subnet(host_ip)
    run_privileged(["sysctl", "-w", "net.ipv4.ip_forward=1"])
    cleanup = []
    for table, chain, rule in [
        ("nat", "POSTROUTING", ["-s", subnet, "!", "-o", tap, "-j", "MASQUERADE"]),
        (None, "FORWARD", ["-i", tap, "-j", "ACCEPT"]),
        (
            None,
            "FORWARD",
            ["-o", tap, "-m", "conntrack", "--ctstate", "RELATED,ESTABLISHED", "-j", "ACCEPT"],
        ),
    ]:
        delete_command = ensure_iptables_rule(table, chain, rule)
        if delete_command is not None:
            cleanup.append(delete_command)
    log(f"guest NAT enabled for {subnet} via {tap}")
    return cleanup


def cleanup_guest_nat(cleanup_commands):
    for command in reversed(cleanup_commands):
        run_privileged(command, check=False)


def firecracker_dns_servers():
    raw = os.environ.get("PROJ_CREATOR_FIRECRACKER_DNS_SERVERS", "1.1.1.1,8.8.8.8")
    servers = [part.strip() for part in re.split(r"[,\s]+", raw) if part.strip()]
    if not servers:
        fail("PROJ_CREATOR_FIRECRACKER_DNS_SERVERS did not contain any DNS servers")
    return servers


def configure_guest_dns(root_ssh_base, dns_servers):
    lines = "".join(f"nameserver {server}\n" for server in dns_servers)
    script = f"printf '%s' {shlex.quote(lines)} > /etc/resolv.conf"
    ssh_command(root_ssh_base, script)
    log(f"configured guest DNS servers: {', '.join(dns_servers)}")


LOCAL_URL_RE = re.compile(
    r"http://(?P<host>127\.0\.0\.1|localhost|host\.docker\.internal|172\.17\.0\.1)(?P<port>:\d+)?"
)

BASE64_TOKEN_RE = re.compile(r"(?<![A-Za-z0-9+/=])([A-Za-z0-9+/]{32,}={0,2})(?![A-Za-z0-9+/=])")


def rewrite_local_urls(value, gateway_ip):
    return LOCAL_URL_RE.sub(lambda match: f"http://{gateway_ip}{match.group('port') or ''}", value)


def rewrite_base64_local_urls(value, gateway_ip):
    def replace(match):
        token = match.group(1)
        padded = token + ("=" * ((4 - len(token) % 4) % 4))
        try:
            decoded = base64_decode(padded)
        except ValueError:
            return token
        rewritten = rewrite_local_urls(decoded, gateway_ip)
        if rewritten == decoded:
            return token
        return base64_encode(rewritten)

    return BASE64_TOKEN_RE.sub(replace, value)


def base64_decode(value):
    import base64

    try:
        decoded = base64.b64decode(value, validate=True)
        text = decoded.decode("utf-8")
    except Exception as err:
        raise ValueError(str(err)) from err
    if "\x00" in text:
        raise ValueError("decoded token contains NUL")
    return text


def base64_encode(value):
    import base64

    return base64.b64encode(value.encode("utf-8")).decode("ascii")


def rewrite_guest_connectivity(value, gateway_ip):
    return rewrite_base64_local_urls(rewrite_local_urls(value, gateway_ip), gateway_ip)


def collect_local_url_ports(value):
    ports = set()

    def collect_from_text(text):
        for match in LOCAL_URL_RE.finditer(text):
            port = match.group("port")
            ports.add(int(port[1:]) if port else 80)

    collect_from_text(value)
    for match in BASE64_TOKEN_RE.finditer(value):
        token = match.group(1)
        padded = token + ("=" * ((4 - len(token) % 4) % 4))
        try:
            collect_from_text(base64_decode(padded))
        except ValueError:
            continue
    return ports


def pipe_bidirectional(client, upstream):
    sockets = [client, upstream]
    try:
        while sockets:
            readable, _, _ = select.select(sockets, [], [], 30)
            if not readable:
                return
            for source in readable:
                data = source.recv(65536)
                if not data:
                    return
                target = upstream if source is client else client
                target.sendall(data)
    except OSError:
        return
    finally:
        for sock in (client, upstream):
            try:
                sock.close()
            except OSError:
                pass


def start_loopback_proxy(bind_host, port):
    listener = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    listener.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        listener.bind((bind_host, port))
        listener.listen(64)
    except OSError as err:
        listener.close()
        log(f"loopback proxy skipped for {bind_host}:{port}: {err}")
        return None

    stop = threading.Event()

    def accept_loop():
        while not stop.is_set():
            try:
                client, _ = listener.accept()
            except OSError:
                return
            try:
                upstream = socket.create_connection(("127.0.0.1", port), timeout=10)
            except OSError as err:
                log(f"loopback proxy failed to connect 127.0.0.1:{port}: {err}")
                client.close()
                continue
            threading.Thread(target=pipe_bidirectional, args=(client, upstream), daemon=True).start()

    threading.Thread(target=accept_loop, daemon=True).start()
    log(f"loopback proxy listening on {bind_host}:{port} -> 127.0.0.1:{port}")
    return listener, stop


def stop_loopback_proxies(proxies):
    for listener, stop in proxies:
        stop.set()
        try:
            listener.close()
        except OSError:
            pass


def main():
    request = json.load(sys.stdin)
    rootfs = Path(request["rootfs"]).resolve()
    kernel = Path(request["kernel_image"]).resolve()
    run_dir = Path(request["run_dir"]).resolve()
    repo = Path(request["repo"]).resolve()
    workdir = request.get("workdir") or "/workspace"
    selected_image = request["selected_image"]
    inner_script = request["inner_script"]
    envs = request.get("envs") or []
    workspace_uid = int(request.get("workspace_uid") or 10001)
    workspace_gid = int(request.get("workspace_gid") or 10001)

    if not rootfs.is_file():
        fail(f"rootfs does not exist: {rootfs}")
    if not kernel.is_file():
        fail(f"kernel image does not exist: {kernel}")
    if not repo.is_dir():
        fail(f"repo directory does not exist: {repo}")

    firecracker = require_command("firecracker")
    for command in ["docker", "e2fsck", "ip", "resize2fs", "ssh", "ssh-keygen", "tar", "truncate", "mount", "umount"]:
        require_command(command)

    run_dir.mkdir(parents=True, exist_ok=True)
    emit_status("setup", "Preparing Firecracker run directory")
    socket_id = hashlib.sha256(str(run_dir).encode("utf-8")).hexdigest()[:16]
    api_socket = Path(os.environ.get("TMPDIR", "/tmp")) / f"pcfc-{socket_id}.sock"
    key_path = run_dir / "guest_ssh_key"
    mount_dir = run_dir / "rootfs-mount"
    log_path = run_dir / "firecracker.log"
    metrics_path = run_dir / "firecracker-metrics.json"
    mount_dir.mkdir(parents=True, exist_ok=True)
    for path in [api_socket, key_path, key_path.with_suffix(".pub")]:
        try:
            path.unlink()
        except FileNotFoundError:
            pass

    emit_status("setup", "Preparing Firecracker rootfs")
    grow_rootfs(rootfs)
    run(["ssh-keygen", "-q", "-t", "ed25519", "-N", "", "-f", str(key_path)])
    public_key = key_path.with_suffix(".pub").read_text(encoding="utf-8").strip()
    emit_status("setup", "Injecting guest SSH key")
    inject_ssh_key(rootfs, mount_dir, public_key)

    tap, host_ip, guest_ip, mac = stable_network(run_dir)
    local_proxy_ports = collect_local_url_ports(inner_script)
    for _, value in envs:
        local_proxy_ports.update(collect_local_url_ports(str(value)))
    inner_script = rewrite_guest_connectivity(inner_script, host_ip)
    envs = [(key, rewrite_guest_connectivity(str(value), host_ip)) for key, value in envs]
    firecracker_process = None
    fc_log = None
    loopback_proxies = []
    nat_cleanup = []
    exit_code = 1
    try:
        emit_status("setup", "Configuring Firecracker network")
        # A killed runner can leave the deterministic per-run tap behind. Drop
        # it before recreating the device so retries are idempotent.
        run_privileged(["ip", "link", "del", tap], check=False)
        run_privileged(["ip", "tuntap", "add", "dev", tap, "mode", "tap", "user", str(os.getuid())])
        run_privileged(["ip", "addr", "add", f"{host_ip}/24", "dev", tap])
        run_privileged(["ip", "link", "set", tap, "up"])
        nat_cleanup = setup_guest_nat(tap, host_ip)
        for port in sorted(local_proxy_ports):
            proxy = start_loopback_proxy(host_ip, port)
            if proxy is not None:
                loopback_proxies.append(proxy)

        fc_log = log_path.open("ab")
        emit_status("run", "Starting Firecracker VM")
        firecracker_process = subprocess.Popen(
            [firecracker, "--api-sock", str(api_socket)],
            stdout=fc_log,
            stderr=fc_log,
        )
        wait_for_path(api_socket, 10, "Firecracker API socket")

        boot_args = (
            "console=ttyS0 reboot=k panic=1 pci=off "
            "root=/dev/vda rw init=/sbin/proj-creator-init "
            f"ip={guest_ip}::{host_ip}:255.255.255.0::eth0:off"
        )
        firecracker_request(api_socket, "PUT", "/logger", {
            "log_path": str(log_path),
            "level": "Info",
            "show_level": True,
            "show_log_origin": True,
        })
        firecracker_request(api_socket, "PUT", "/metrics", {"metrics_path": str(metrics_path)})
        firecracker_request(api_socket, "PUT", "/machine-config", {
            "vcpu_count": int(os.environ.get("PROJ_CREATOR_FIRECRACKER_VCPUS", "2")),
            "mem_size_mib": int(os.environ.get("PROJ_CREATOR_FIRECRACKER_MEM_MIB", "8192")),
            "smt": False,
        })
        firecracker_request(api_socket, "PUT", "/boot-source", {
            "kernel_image_path": str(kernel),
            "boot_args": boot_args,
        })
        firecracker_request(api_socket, "PUT", "/drives/rootfs", {
            "drive_id": "rootfs",
            "path_on_host": str(rootfs),
            "is_root_device": True,
            "is_read_only": False,
        })
        firecracker_request(api_socket, "PUT", "/network-interfaces/eth0", {
            "iface_id": "eth0",
            "guest_mac": mac,
            "host_dev_name": tap,
        })
        firecracker_request(api_socket, "PUT", "/actions", {"action_type": "InstanceStart"})

        ssh_base = [
            "ssh",
            "-i", str(key_path),
            "-o", "StrictHostKeyChecking=no",
            "-o", "UserKnownHostsFile=/dev/null",
            "-o", "ConnectTimeout=3",
            "-o", "ServerAliveInterval=15",
            "-o", "ServerAliveCountMax=2",
            f"appuser@{guest_ip}",
        ]
        root_ssh_base = [
            "ssh",
            "-i", str(key_path),
            "-o", "StrictHostKeyChecking=no",
            "-o", "UserKnownHostsFile=/dev/null",
            "-o", "ConnectTimeout=3",
            "-o", "ServerAliveInterval=15",
            "-o", "ServerAliveCountMax=2",
            f"root@{guest_ip}",
        ]
        dns_servers = firecracker_dns_servers()
        emit_status("run", "Waiting for guest SSH")
        wait_for_ssh(ssh_base, 120)
        emit_status("run", "Configuring guest DNS")
        configure_guest_dns(root_ssh_base, dns_servers)
        emit_status("run", "Waiting for guest Docker")
        ssh_command(
            ssh_base,
            "for i in $(seq 1 120); do docker info >/dev/null 2>&1 && exit 0; sleep 1; done; exit 1",
        )
        emit_status("run", "Loading agent image into guest")
        log(f"loading agent image into guest: {selected_image}")
        load_docker_image_to_guest(ssh_base, selected_image)

        workspace_target = container_workspace_target(workdir)
        guest_workspace = workspace_target
        emit_status("workspace", "Staging workspace into guest")
        log(f"staging workspace into guest {guest_workspace}")
        tar_to_guest(ssh_base, repo, guest_workspace)
        chown_guest_workspace(root_ssh_base, guest_workspace, workspace_uid, workspace_gid)

        guest_mounts = []
        for mount in request.get("mounts") or []:
            guest_path = str(mount.get("guest_path") or "")
            host_path = str(mount.get("host_path") or "")
            if not guest_path or not host_path:
                continue
            emit_status("workspace", f"Staging support mount {mount.get('purpose') or 'runtime_support'}")
            sync_host_path_to_guest(root_ssh_base, host_path, guest_path, workspace_uid, workspace_gid)
            mode = ":ro" if mount.get("read_only") else ""
            guest_mounts.extend(["-v", f"{guest_path}:{guest_path}{mode}"])

        container_suffix = re.sub(r"[^a-zA-Z0-9_.-]", "-", str(request.get("message_id") or "run"))[:48]
        agent_container_name = f"proj-creator-agent-{container_suffix}"
        docker_args = [
            "docker", "run",
            "--name", agent_container_name,
            "--network", "host",
            "-v", f"{guest_workspace}:{workspace_target}",
            "-w", workspace_target,
            *guest_mounts,
        ]
        for dns_server in dns_servers:
            docker_args.extend(["--dns", dns_server])
        for key, value in envs:
            docker_args.extend(["-e", f"{key}={value}"])
        if request.get("extra_docker_args"):
            docker_args.extend(shlex.split(request["extra_docker_args"]))
        docker_args.extend([selected_image, "/bin/bash", "-lc", inner_script])

        container_name_q = shlex.quote(agent_container_name)
        remote_script = "\n".join([
            "set -uo pipefail",
            "agent_log=/tmp/proj-creator-agent-container.log",
            ": > \"$agent_log\"",
            f"docker rm -f {container_name_q} >/dev/null 2>&1 || true",
            f"{shlex.join(docker_args)} 2>&1 | tee \"$agent_log\"",
            "agent_status=${PIPESTATUS[0]}",
            "codex_marker_status=",
            f"for _ in $(seq 1 20); do "
            "codex_marker_status=$(sed -n 's/^codex_exit_status=//p' \"$agent_log\" | tail -n 1 || true); "
            "[ -n \"$codex_marker_status\" ] && break; "
            "sleep 0.1; "
            "done",
            f"container_status=$(docker inspect --format '{{{{.State.ExitCode}}}}' {container_name_q} 2>/dev/null || true)",
            "case \"$codex_marker_status\" in "
            "''|*[!0-9]* ) "
            "if [ -n \"$container_status\" ]; then agent_status=\"$container_status\"; fi ;; "
            "* ) "
            "if [ \"$agent_status\" -ne \"$codex_marker_status\" ] || [ \"$container_status\" != \"$codex_marker_status\" ]; then "
            "printf '%s\\n' \"guest container status differed from Codex marker; using Codex marker: docker=${agent_status} container=${container_status:-unknown} codex=${codex_marker_status}\" >&2; "
            "fi; "
            "agent_status=\"$codex_marker_status\" ;; "
            "esac",
            "if [ \"$agent_status\" -ne 0 ]; then "
            "printf '%s\\n' \"guest docker run exited with code ${agent_status}\" >&2; "
            "if [ -n \"$container_status\" ]; then printf '%s\\n' \"guest container state exit code ${container_status}\" >&2; fi; "
            "fi",
            f"docker rm -f {container_name_q} >/dev/null 2>&1 || true",
            "exit \"$agent_status\"",
        ])
        emit_status("run", "Running agent container")
        exit_code = ssh_command(ssh_base, remote_script, check=False).returncode
        log(f"guest agent command exited with code {exit_code}")
        fetch_guest_file(root_ssh_base, "/tmp/proj-creator-agent-container.log", run_dir / "agent-container.log")

        for mount in request.get("mounts") or []:
            sync_mount_back_to_host(root_ssh_base, mount, workspace_uid, workspace_gid)
        emit_status("workspace", "Syncing workspace changes from guest")
        log("syncing workspace changes back from guest")
        tar_from_guest(root_ssh_base, guest_workspace, repo)
        chown_host_path(repo, workspace_uid, workspace_gid)
        shutdown_script = (
            "python3 -c 'import ctypes, os; os.sync(); "
            "ctypes.CDLL(None).reboot(0x4321fedc)' "
            "|| poweroff || shutdown -h now || halt -f || true"
        )
        run(["timeout", "8", *root_ssh_base, "bash", "-lc", shlex.quote(shutdown_script)], check=False)
    finally:
        if firecracker_process:
            try:
                firecracker_process.terminate()
                vm_status = firecracker_process.wait(timeout=10)
                log(f"firecracker process exited with code {vm_status}")
            except subprocess.TimeoutExpired:
                log("firecracker process did not exit after terminate; killing")
                firecracker_process.kill()
                vm_status = firecracker_process.wait(timeout=10)
                log(f"firecracker process killed with code {vm_status}")
        if fc_log:
            fc_log.close()
        try:
            api_socket.unlink()
        except FileNotFoundError:
            pass
        if "tap" in locals():
            run_privileged(["ip", "link", "del", tap], check=False)
        cleanup_guest_nat(nat_cleanup)
        stop_loopback_proxies(loopback_proxies)

    raise SystemExit(exit_code)


if __name__ == "__main__":
    main()
